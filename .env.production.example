# ===========================================
# Production Environment Variables
# Ferme du Vardier - Contabo VPS Deployment
# IP: 167.86.111.192
# ===========================================
# Copy this file to .env.production and fill in the values
# Command: cp .env.production.example .env.production

# ============ PostgreSQL ============
POSTGRES_USER=fermeduvardier
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=fermeduvardier

# ============ Redis ============
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE

# ============ URLs ============
FRONTEND_URL=https://fermeduvardier.com
NEXTAUTH_URL=https://fermeduvardier.com
NEXT_PUBLIC_API_URL=https://fermeduvardier.com/api

# ============ NextAuth ============
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET

# ============ Admin ============
ADMIN_EMAIL=admin@fermeduvardier.mg
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ============ OAuth (Optional) ============
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_APP_SECRET=

# ============ SMTP Email ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
